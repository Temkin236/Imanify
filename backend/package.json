{
  "name": "imanify-backend",
  "version": "1.0.0",
  "description": "Imanify Backend API - Quran API with multi-language support",
  "main": "dist/server.js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "quran",
    "islamic",
    "api",
    "rest-api",
    "express",
    "typescript"
  ],
  "author": "Imanify Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.7.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prisma": "^7.7.0",
    "tsx": "^4.18.0",
    "typescript": "^5.5.2",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
